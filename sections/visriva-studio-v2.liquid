<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;800&family=Montserrat:wght@300;400;500;600&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link href="{{ 'visriva-studio-v2.css' | asset_url }}" rel="stylesheet">

{%- comment -%} Look up products by settings selection, fallback handle search, or collection matching {%- endcomment -%}
{%- assign tshirt_prod = all_products[section.settings.tshirt_product] -%}
{%- if tshirt_prod == empty -%}{%- assign tshirt_prod = all_products['custom-t-shirt'] -%}{%- endif -%}
{%- if tshirt_prod == empty -%}{%- assign tshirt_prod = all_products['t-shirt'] -%}{%- endif -%}
{%- if tshirt_prod == empty -%}
  {%- for product in collections.all.products -%}
    {%- if product.handle contains 'custom' or product.handle contains 'design' or product.handle contains 't-shirt' -%}
      {%- assign tshirt_prod = product -%}{%- break -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- assign polo_prod = all_products[section.settings.polo_product] -%}
{%- if polo_prod == empty -%}{%- assign polo_prod = all_products['custom-polo'] -%}{%- endif -%}
{%- if polo_prod == empty -%}{%- assign polo_prod = all_products['polo'] -%}{%- endif -%}

{%- assign sweatshirt_prod = all_products[section.settings.sweatshirt_product] -%}
{%- if sweatshirt_prod == empty -%}{%- assign sweatshirt_prod = all_products['custom-sweatshirt'] -%}{%- endif -%}
{%- if sweatshirt_prod == empty -%}{%- assign sweatshirt_prod = all_products['sweatshirt'] -%}{%- endif -%}

{%- assign hoodie_prod = all_products[section.settings.hoodie_product] -%}
{%- if hoodie_prod == empty -%}{%- assign hoodie_prod = all_products['custom-hoodie'] -%}{%- endif -%}
{%- if hoodie_prod == empty -%}{%- assign hoodie_prod = all_products['hoodie'] -%}{%- endif -%}

<section
  class="studio-v2"
  data-studio-root
  data-default-color="#828FB2"
  data-default-color-name="Acid Wash Blue"
  data-default-wash="acid-blue"
  data-fixed-price="899"
  data-currency-symbol="₹"
  data-model-tshirt-front="https://pub-866993ef9088469599283f550970034a.r2.dev/tshirt-front-texture.png"
  data-model-tshirt-back="https://pub-866993ef9088469599283f550970034a.r2.dev/tshirt-back-texture.png"
>
  <script type="application/json" data-studio-products>
    {
      "tshirt": {
        "label": "T-Shirt",
        "title": {{ tshirt_prod.title | default: "Custom T-Shirt" | json }},
        "variants": [
          {%- if tshirt_prod != empty and tshirt_prod.variants.size > 0 -%}
            {%- for variant in tshirt_prod.variants -%}
              {
                "id": {{ variant.id | json }},
                "title": {{ variant.title | json }},
                "available": {{ variant.available | json }}
              }{%- unless forloop.last -%},{%- endunless -%}
            {%- endfor -%}
          {%- else -%}
            {"id":"47212533547200","title":"S / 430 GSM","available":true},
            {"id":"47212533579968","title":"M / 430 GSM","available":true},
            {"id":"47212533612736","title":"L / 430 GSM","available":true},
            {"id":"47212533645504","title":"XL / 430 GSM","available":true},
            {"id":"47212533678272","title":"2XL / 430 GSM","available":true}
          {%- endif -%}
        ]
      },
      "polo": {
        "label": "Polo",
        "title": {{ polo_prod.title | default: "Custom Polo" | json }},
        "variants": [
          {%- if polo_prod != empty and polo_prod.variants.size > 0 -%}
            {%- for variant in polo_prod.variants -%}
              {
                "id": {{ variant.id | json }},
                "title": {{ variant.title | json }},
                "available": {{ variant.available | json }}
              }{%- unless forloop.last -%},{%- endunless -%}
            {%- endfor -%}
          {%- else -%}
            {"id":"47212533547200","title":"S / 430 GSM","available":true},
            {"id":"47212533579968","title":"M / 430 GSM","available":true},
            {"id":"47212533612736","title":"L / 430 GSM","available":true},
            {"id":"47212533645504","title":"XL / 430 GSM","available":true},
            {"id":"47212533678272","title":"2XL / 430 GSM","available":true}
          {%- endif -%}
        ]
      },
      "sweatshirt": {
        "label": "Sweatshirt",
        "title": {{ sweatshirt_prod.title | default: "Custom Sweatshirt" | json }},
        "variants": [
          {%- if sweatshirt_prod != empty and sweatshirt_prod.variants.size > 0 -%}
            {%- for variant in sweatshirt_prod.variants -%}
              {
                "id": {{ variant.id | json }},
                "title": {{ variant.title | json }},
                "available": {{ variant.available | json }}
              }{%- unless forloop.last -%},{%- endunless -%}
            {%- endfor -%}
          {%- else -%}
            {"id":"47212533547200","title":"S / 430 GSM","available":true},
            {"id":"47212533579968","title":"M / 430 GSM","available":true},
            {"id":"47212533612736","title":"L / 430 GSM","available":true},
            {"id":"47212533645504","title":"XL / 430 GSM","available":true},
            {"id":"47212533678272","title":"2XL / 430 GSM","available":true}
          {%- endif -%}
        ]
      },
      "hoodie": {
        "label": "Hoodie",
        "title": {{ hoodie_prod.title | default: "Custom Hoodie" | json }},
        "variants": [
          {%- if hoodie_prod != empty and hoodie_prod.variants.size > 0 -%}
            {%- for variant in hoodie_prod.variants -%}
              {
                "id": {{ variant.id | json }},
                "title": {{ variant.title | json }},
                "available": {{ variant.available | json }}
              }{%- unless forloop.last -%},{%- endunless -%}
            {%- endfor -%}
          {%- else -%}
            {"id":"47212533547200","title":"S / 430 GSM","available":true},
            {"id":"47212533579968","title":"M / 430 GSM","available":true},
            {"id":"47212533612736","title":"L / 430 GSM","available":true},
            {"id":"47212533645504","title":"XL / 430 GSM","available":true},
            {"id":"47212533678272","title":"2XL / 430 GSM","available":true}
          {%- endif -%}
        ]
      }
    }
  </script>

  <div class="studio-v2-shell">
    <header class="studio-v2-head">
      <h1>Build Your Superdesign</h1>
      <p>Choose garment, size, color and edit your artwork directly on front and back previews.</p>
    </header>

    <div class="studio-v2-layout">
      <!-- LEFT: Preview Column -->
      <div class="studio-v2-preview-column">
        <div class="studio-v2-preview-grid">
          <article class="studio-v2-preview-card is-active" data-studio-preview-card="front">
            <h3>Front</h3>
            <div class="studio-v2-frame-wrapper">
              <span class="frame-corner corner-tl"></span>
              <span class="frame-corner corner-tr"></span>
              <span class="frame-corner corner-bl"></span>
              <span class="frame-corner corner-br"></span>
              <canvas width="440" height="560" data-studio-canvas="front" aria-label="Front preview canvas"></canvas>
            </div>
            <p class="studio-v2-model-hint">Click to edit front design</p>
          </article>
          <article class="studio-v2-preview-card" data-studio-preview-card="back">
            <h3>Back</h3>
            <div class="studio-v2-frame-wrapper">
              <span class="frame-corner corner-tl"></span>
              <span class="frame-corner corner-tr"></span>
              <span class="frame-corner corner-bl"></span>
              <span class="frame-corner corner-br"></span>
              <canvas width="440" height="560" data-studio-canvas="back" aria-label="Back preview canvas"></canvas>
            </div>
            <p class="studio-v2-model-hint">Click to edit back design</p>
          </article>
        </div>

        <div class="studio-v2-summary" aria-live="polite">
          <p><span>Garment</span><strong data-studio-garment-readout>T-Shirt</strong></p>
          <p><span>Size</span><strong data-studio-size-readout>Not selected</strong></p>
          <p><span>GSM</span><strong data-studio-gsm-readout>Not selected</strong></p>
          <p><span>Material</span><strong data-studio-material-readout>Not selected</strong></p>
          <p><span>Selected color</span><strong data-studio-color-readout>Acid Wash Blue</strong></p>
          <p><span>Wash finish</span><strong data-studio-wash-readout>Acid Wash Blue</strong></p>
          <p><span>Front Artwork</span><strong data-studio-file-readout-front>No file uploaded</strong></p>
          <p><span>Back Artwork</span><strong data-studio-file-readout-back>No file uploaded</strong></p>
        </div>
      </div>

      <!-- RIGHT: Form Column -->
      {%- assign form_product = tshirt_prod -%}
      {%- if form_product.id == nil -%}
        {%- assign form_product = polo_prod -%}
      {%- endif -%}
      {%- if form_product.id == nil -%}
        {%- assign form_product = sweatshirt_prod -%}
      {%- endif -%}
      {%- if form_product.id == nil -%}
        {%- assign form_product = collections.all.products.first -%}
      {%- endif -%}

      {%- form 'product', form_product, class: 'studio-v2-form', data-studio-form: '', enctype: 'multipart/form-data' -%}
        <input type="hidden" name="id" value="47212533547200" data-studio-variant-id>
        <input type="hidden" name="properties[Size]" value="" data-studio-size-property>
        <input type="hidden" name="properties[GSM]" value="" data-studio-gsm-property>
        <input type="hidden" name="properties[Material Type]" value="" data-studio-material-property>
        <input type="hidden" name="properties[Garment Color]" value="Acid Wash Blue (#828FB2)" data-studio-color-property>
        <input type="hidden" name="properties[Wash Finish]" value="Acid Wash Blue" data-studio-wash-property>
        <input type="hidden" name="properties[Color Source]" value="Acid swatch" data-studio-color-source-property>
        <input type="hidden" name="properties[Custom Color Hex]" value="" data-studio-custom-color-property>
        <input type="hidden" name="properties[Print Scale]" value="100%" data-studio-scale-property>
        <input type="hidden" name="properties[Front Artwork Name]" value="" data-studio-artwork-front-name-property>
        <input type="hidden" name="properties[Back Artwork Name]" value="" data-studio-artwork-back-name-property>
        <input type="hidden" name="properties[Front Artwork Transform]" value="" data-studio-front-transform-property>
        <input type="hidden" name="properties[Back Artwork Transform]" value="" data-studio-back-transform-property>
        <input type="hidden" name="properties[Quoted Price]" value="₹899" data-studio-quoted-price-property>
        <input type="file" name="properties[Front Preview Snapshot]" accept="image/png" class="studio-v2-hidden-input" data-studio-front-shot tabindex="-1" aria-hidden="true">
        <input type="file" name="properties[Back Preview Snapshot]" accept="image/png" class="studio-v2-hidden-input" data-studio-back-shot tabindex="-1" aria-hidden="true">

        <div class="studio-v2-fieldset">
          <label class="studio-v2-label" for="studio-garment">Garment type</label>
          <div class="studio-v2-select-wrap">
            <select id="studio-garment" name="properties[Garment Type]" data-studio-garment>
              <option value="tshirt" selected>T-Shirt</option>
              <option value="polo">Polo</option>
              <option value="sweatshirt">Sweatshirt</option>
              <option value="hoodie">Hoodie</option>
            </select>
          </div>

          <div data-studio-material-wrapper style="margin-top:1.5rem;">
            <label class="studio-v2-label" for="studio-material">Material type</label>
            <div class="studio-v2-select-wrap">
              <select id="studio-material" data-studio-material>
                <option value="Cotton">Cotton</option>
                <option value="Polyester">Polyester</option>
                <option value="Cotton Blend">Cotton Blend</option>
                <option value="Cotton Poly Blend">Cotton Poly Blend</option>
              </select>
            </div>
          </div>

          <div data-studio-gsm-wrapper style="margin-top:1.5rem;">
            <label class="studio-v2-label" for="studio-gsm">GSM</label>
            <div class="studio-v2-select-wrap">
              <select id="studio-gsm" data-studio-gsm>
                <!-- populated dynamically -->
              </select>
            </div>
          </div>

          <label class="studio-v2-label" style="margin-top:1.5rem">Size</label>
          <div class="studio-v2-sizes-container" data-studio-sizes-container role="radiogroup" aria-label="Select size"></div>
          <select id="studio-size" class="studio-v2-hidden-input" data-studio-size tabindex="-1" aria-hidden="true"></select>
        </div>

        <div class="studio-v2-fieldset">
          <label class="studio-v2-label">Acid wash colors</label>
          <div class="studio-v2-swatches" role="listbox" aria-label="Acid wash color selection">
            <button type="button" class="studio-v2-swatch is-active" data-studio-swatch data-color="#828FB2" data-color-name="Acid Wash Blue" data-wash="acid-blue" aria-label="Acid Wash Blue">
              <span class="studio-v2-swatch-chip" style="--swatch-base:#828FB2;--swatch-a:rgba(224,232,250,.55);--swatch-b:rgba(52,63,92,.58);--swatch-c:rgba(151,166,200,.42);"></span>
              <span class="studio-v2-swatch-name">Acid Blue</span>
            </button>
            <button type="button" class="studio-v2-swatch" data-studio-swatch data-color="#1F262A" data-color-name="Washed Black" data-wash="acid-black" aria-label="Washed Black">
              <span class="studio-v2-swatch-chip" style="--swatch-base:#1F262A;--swatch-a:rgba(237,239,244,.34);--swatch-b:rgba(13,17,20,.66);--swatch-c:rgba(151,158,171,.3);"></span>
              <span class="studio-v2-swatch-name">Washed Black</span>
            </button>
            <button type="button" class="studio-v2-swatch" data-studio-swatch data-color="#1E4D2B" data-color-name="Acid Wash Green" data-wash="acid-green" aria-label="Acid Wash Green">
              <span class="studio-v2-swatch-chip" style="--swatch-base:#1E4D2B;--swatch-a:rgba(190,224,198,.42);--swatch-b:rgba(16,36,22,.52);--swatch-c:rgba(96,139,110,.32);"></span>
              <span class="studio-v2-swatch-name">Acid Green</span>
            </button>
            <button type="button" class="studio-v2-swatch" data-studio-swatch data-color="#DB6A6C" data-color-name="Acid Wash Red" data-wash="acid-red" aria-label="Acid Wash Red">
              <span class="studio-v2-swatch-chip" style="--swatch-base:#DB6A6C;--swatch-a:rgba(255,222,222,.52);--swatch-b:rgba(126,40,46,.54);--swatch-c:rgba(235,157,159,.38);"></span>
              <span class="studio-v2-swatch-name">Acid Red</span>
            </button>
            <button type="button" class="studio-v2-swatch" data-studio-swatch data-color="#111111" data-color-name="Onyx Solid" data-wash="solid" aria-label="Onyx Solid">
              <span class="studio-v2-swatch-chip" style="--swatch-base:#111111;--swatch-a:rgba(255,255,255,.2);--swatch-b:rgba(10,10,10,.35);--swatch-c:rgba(0,0,0,.1);"></span>
              <span class="studio-v2-swatch-name">Onyx</span>
            </button>
            <button type="button" class="studio-v2-swatch" data-studio-swatch data-color="#EFEDE8" data-color-name="Ivory Solid" data-wash="solid" aria-label="Ivory Solid">
              <span class="studio-v2-swatch-chip" style="--swatch-base:#EFEDE8;--swatch-a:rgba(255,255,255,.65);--swatch-b:rgba(215,211,202,.45);--swatch-c:rgba(227,221,209,.3);"></span>
              <span class="studio-v2-swatch-name">Ivory</span>
            </button>
          </div>
        </div>

        <div class="studio-v2-fieldset">
          <label class="studio-v2-label">Custom color</label>
          <div class="studio-v2-custom-color-row">
            <input type="color" value="#828FB2" data-studio-custom-color-picker aria-label="Select custom color">
            <input type="text" value="#828FB2" maxlength="7" data-studio-custom-color-hex aria-label="Custom color hex">
            <button type="button" class="studio-v2-small-button" data-studio-custom-color-apply>Apply</button>
          </div>
          <p class="studio-v2-help">Use this for any exact color beyond acid wash swatches.</p>
        </div>

        <div class="studio-v2-fieldset">
          <label class="studio-v2-label" for="studio-upload-front">Upload Front Artwork</label>
          <input id="studio-upload-front" class="studio-v2-native-upload" type="file" name="properties[Uploaded Front Artwork]" data-studio-upload-front accept="image/png,image/jpeg,image/webp">
          <div class="studio-v2-upload-row" style="margin-bottom:1rem;">
            <button type="button" class="studio-v2-small-button" data-studio-upload-trigger-front>Choose front artwork</button>
            <span class="studio-v2-upload-name" data-studio-upload-name-front>No file selected</span>
          </div>

          <label class="studio-v2-label" for="studio-upload-back" style="margin-top:1rem; display:block;">Upload Back Artwork</label>
          <input id="studio-upload-back" class="studio-v2-native-upload" type="file" name="properties[Uploaded Back Artwork]" data-studio-upload-back accept="image/png,image/jpeg,image/webp">
          <div class="studio-v2-upload-row">
            <button type="button" class="studio-v2-small-button" data-studio-upload-trigger-back>Choose back artwork</button>
            <span class="studio-v2-upload-name" data-studio-upload-name-back>No file selected</span>
          </div>
        </div>

        <div class="studio-v2-fieldset">
          <label class="studio-v2-label" for="studio-placement">Artwork placement</label>
          <div class="studio-v2-select-wrap">
            <select id="studio-placement" name="properties[Artwork Placement]" data-studio-placement>
              <option value="front">Front only</option>
              <option value="back">Back only</option>
              <option value="both" selected>Front and back</option>
            </select>
          </div>
        </div>

        <div class="studio-v2-fieldset">
          <label class="studio-v2-label">Edit on model</label>
          <div class="studio-v2-edit-tabs">
            <button type="button" class="studio-v2-edit-tab is-active" data-studio-edit-side="front">Edit front</button>
            <button type="button" class="studio-v2-edit-tab" data-studio-edit-side="back">Edit back</button>
          </div>
          <p class="studio-v2-help">Drag artwork on preview to move. Drag the corner handle to scale.</p>
          <button type="button" class="studio-v2-small-button" data-studio-reset-side>Reset active side</button>
        </div>

        <div class="studio-v2-fieldset">
          <label class="studio-v2-label" for="studio-notes">Customization notes</label>
          <textarea id="studio-notes" name="properties[Customization Notes]" rows="3" placeholder="Anything extra we should know about your design?"></textarea>
        </div>

        <p class="studio-v2-status" data-studio-status aria-live="polite"></p>

        <button type="submit" class="studio-v2-submit" data-studio-submit>
          Add to cart — <span data-studio-price>₹899</span>
        </button>
      {%- endform -%}
    </div>
  </div>
</section>

<script src="{{ 'visriva-studio-v2.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "VISRIVA Studio V2",
  "tag": "section",
  "class": "visriva-studio-v2-section",
  "settings": [
    {
      "type": "header",
      "content": "Garment Product Mappings"
    },
    {
      "type": "paragraph",
      "content": "Select the products from your Shopify catalog that correspond to each garment type. The customizer will dynamically load their active variants (sizes, inventory, prices, and IDs)."
    },
    {
      "type": "product",
      "id": "tshirt_product",
      "label": "Custom T-Shirt Product"
    },
    {
      "type": "product",
      "id": "polo_product",
      "label": "Custom Polo Product"
    },
    {
      "type": "product",
      "id": "sweatshirt_product",
      "label": "Custom Sweatshirt Product"
    },
    {
      "type": "product",
      "id": "hoodie_product",
      "label": "Custom Hoodie Product"
    }
  ],
  "presets": [
    {
      "name": "VISRIVA Studio V2"
    }
  ]
}
{% endschema %}
