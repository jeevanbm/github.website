<!doctype html>
<html
  class="no-js{% if request.design_mode %} shopify-design-mode{% endif %}"
  lang="{{ request.locale.iso_code }}"
>
  <head>
    {%- render 'stylesheets' -%}

    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% # theme-check-disable RemoteAsset %}
    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    {% if settings.transition_to_main_product or settings.page_transition_enabled %}
      <link
        rel="expect"
        href="#MainContent"
        blocking="render"
        id="view-transition-render-blocker"
      >
    {% endif %}

    {%- render 'meta-tags' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    <style>
      /* Global Background Image (All Pages) */
      html, body {
        background-color: #040d0a !important;
        background-image: url("{{ 'Backgroundimage.png' | asset_url }}") !important;
        background-size: cover !important;
        background-position: center top !important;
        background-repeat: no-repeat !important;
        background-attachment: fixed !important;
      }
      /* Force Custom Image Logo and Remove Text Logo Fallbacks */
      .logo-section__image-wrapper, .logo-section__image, .header-logo img, .logo-monogram, .logo-inline img {
        display: none !important; 
      }
      .header-logo, .logo-title {
        font-size: 0 !important;
        color: transparent !important;
        background: transparent !important;
        background-color: transparent !important;
        outline: none !important;
        border: none !important;
        box-shadow: none !important;
      }
      .header-logo:hover, .header-logo:focus, .header-logo:active, .header-logo:focus-visible,
      .logo-title:hover, .logo-title:focus, .logo-title:active {
        background: transparent !important;
        background-color: transparent !important;
        outline: none !important;
        border: none !important;
        box-shadow: none !important;
      }
      .logo-section jumbo-text, .logo-block jumbo-text {
        display: none !important;
      }
      .logo-title, .logo-section::after, .header-logo::after, .logo-inline::after {
        content: "";
        display: inline-block;
        background-image: url("{{ 'visriva-logo.png' | asset_url }}");
        background-size: contain;
        background-repeat: no-repeat;
        background-position: center;
        width: 180px;
        height: 50px;
      }
      .header__column--left .header-logo::after {
        background-position: center left;
      }
      .logo-section::after {
        width: 250px;
        height: 80px;
      }
      /* Global Transparency & Glassmorphism for Global Background Visibility */
      body,
      #MainContent,
      .section,
      .section-background,
      .color-scheme-1,
      .color-scheme-2,
      .color-scheme-3,
      .color-scheme-4,
      .color-scheme-5,
      .color-scheme-primary,
      .color-scheme-secondary,
      .color-scheme-tertiary {
        background-color: transparent !important;
        background-image: none !important;
      }
      /* Premium glass card look for section containers */
      .card-container,
      .product-card,
      .collection-card,
      .blog-post-card,
      .slideshow__slide,
      .password-main-content,
      .password-dialog {
        background: rgba(0, 0, 0, 0.65) !important;
        backdrop-filter: blur(16px) saturate(180%) !important;
        -webkit-backdrop-filter: blur(16px) saturate(180%) !important;
        border: 1px solid rgba(212, 175, 55, 0.45) !important;
        border-radius: 12px !important;
        box-shadow: 0 8px 32px rgba(191, 149, 63, 0.15) !important;
      }
      /* Title and Typography font overrides */
      h1, h2, h3, h4, h5, h6, .h1, .h2, .h3, .h4, .h5, .h6, .logo-title, .logo-section jumbo-text {
        font-family: 'Cinzel', serif !important;
        text-transform: uppercase !important;
        color: #fcf6ba !important;
        text-shadow: 0 0 10px rgba(252, 246, 186, 0.25) !important;
      }
      p, span, li, a, div:not(#visriva-superdesigner-root *) {
        color: #ffffff !important;
        text-shadow: 0 1px 3px rgba(0, 0, 0, 0.8) !important;
      }
    </style>
    <link href="{{ 'visriva-global.css' | asset_url }}" rel="stylesheet">

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {{ content_for_header }}
    {% # theme-check-enable RemoteAsset %}
  </head>

  <body class="page-width-{{ settings.page_width }}">
    <main
      id="MainContent"
      class="content-for-layout password-main-content"
      role="main"
    >
      {{ content_for_layout }}
    </main>

    <footer>
      {% section 'password-footer' %}
    </footer>

    {%- form 'storefront_password' -%}
      <dialog-component id="password-form">
        <dialog
          ref="dialog"
          class="password-dialog"
          {% if form.errors %}
            open
          {% endif %}
          aria-labelledby="password-dialog-heading"
        >
          <div class="password-dialog__header">
            <button
              class="button-unstyled close-button password-dialog__close-button"
              on:click="dialog-component/closeDialog"
              type="button"
            >
              <span
                class="svg-wrapper svg-wrapper--small"
                title="{{ 'actions.close' | t }}"
              >
                {{ 'icon-close.svg' | inline_asset_content }}
              </span>
            </button>
          </div>
          <div class="password-dialog__content">
            <h2
              id="password-dialog-heading"
              class="password-dialog__title h3"
            >
              {{ 'actions.enter_password' | t }}
            </h2>

            <div class="email-signup__input-group">
              <label
                for="Password"
                class="visually-hidden"
              >
                {{ 'placeholders.password' | t }}
              </label>

              <input
                type="password"
                name="password"
                id="Password"
                class="field__input field__input--button-radius field__input--button-padding"
                autocomplete="current-password"
                {% if form.errors %}
                  aria-invalid="true"
                  aria-describedby="PasswordLoginForm-password-error"
                {%- endif -%}
                placeholder="{{ 'placeholders.password' | t }}"
                autofocus
              >

              <button
                class="button password-dialog__submit-button"
                type="submit"
              >
                {{ 'actions.submit' | t }}
              </button>
            </div>

            {%- if form.errors -%}
              <div
                id="PasswordLoginForm-password-error"
                class="email-signup__message"
                tabindex="-1"
              >
                <svg
                  viewBox="0 0 20 20"
                  xmlns="http://www.w3.org/2000/svg"
                  focusable="false"
                  aria-hidden="true"
                  class="icon-error"
                >
                  {%- render 'icon', icon: 'error'  -%}
                </svg>
                {{ 'content.wrong_password' | t }}
              </div>
            {%- endif -%}
          </div>
        </dialog>
      </dialog-component>
    {%- endform -%}

    {%- render 'password-layout-styles' -%}
  </body>
</html>
